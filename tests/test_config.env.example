# BinDist Test Configuration
# Copy this file to test_config.env and fill in your values

# API URL - changes on each deployment
# Get this from terraform output: terraform output -raw api_endpoint
BINDIST_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/v1

# Tenant ID (UUID format)
TENANT_ID=your-tenant-uuid-here

# API Secret (the part after the dot in your API key)
API_SECRET=your-api-secret-here

# Path to PowerShell scripts (relative to this file or absolute)
SCRIPTS_PATH=../../aws-exe-dist/scripts
